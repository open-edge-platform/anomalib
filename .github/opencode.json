{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (self-hosted GPU)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:27b": {
          "name": "Qwen 3.6 27B",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "ollama/qwen3.6:27b",
  "agent": {
    "issue-triage": {
      "description": "Triages new GitHub issues — classifies type, sets priority, detects duplicates, requests info, assigns owner",
      "model": "ollama/gemma4:31b",
      "prompt": "{file:agents/issue-triage-opencode.md}",
      "temperature": 0.1,
      "steps": 10,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "deny",
          "gh issue *": "allow",
          "gh search *": "allow",
          "gh label *": "allow",
          "gh api *": "allow"
        }
      }
    },
    "docs-sync": {
      "description": "Detects documentation drift from recent code changes and opens a PR with fixes",
      "model": "ollama/qwen3.6:27b",
      "prompt": "{file:agents/docs-sync-opencode.md}",
      "temperature": 0.1,
      "steps": 30,
      "permission": {
        "read": "allow",
        "edit": {
          "*": "deny",
          "*.md": "allow",
          "*.rst": "allow",
          "*.mdx": "allow",
          "docs/**": "allow",
          "src/anomalib/models/**/README.md": "allow",
          "README.md": "allow"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "gh pr *": "allow",
          "gh api *": "allow",
          "gh search *": "allow"
        }
      }
    },
    "agents-md-sync": {
      "description": "Maintains AGENTS.md knowledge base by reviewing merged PRs and structural changes",
      "model": "ollama/qwen3.6:27b",
      "prompt": "{file:agents/agents-md-sync-opencode.md}",
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "read": "allow",
        "edit": {
          "*": "deny",
          "AGENTS.md": "allow"
        },
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "gh pr *": "allow",
          "gh api *": "allow",
          "gh search *": "allow",
          "ls *": "allow"
        }
      }
    }
  }
}
